# Generated on first run if /config/.env is missing.
# After initial creation, this file persists and is NOT overwritten by default.env changes.
# To update existing deployments: either edit /config/.env directly, or pass environment
# variables (e.g., docker run -e AUTO_BOOTSTRAP_POINTS=624) which override file values.
APP_ENV=production
APP_NAME=agile-predict-api
APP_VERSION=0.1.0

# Database mode: local or external
DB_MODE=local
POSTGRES_DB=agile_predict
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_DATA_DIR=/config/postgresql
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/agile_predict

# Automated database backups (only when DB_MODE=local)
BACKUP_DIR=/config/backups
LOG_DIR=/config/logs
BACKUP_HOUR=3
BACKUPS_TO_KEEP=7

# Backend runtime
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5173,http://127.0.0.1:5173
AUTO_BOOTSTRAP_ON_STARTUP=true
AUTO_BOOTSTRAP_MODE=update
AUTO_BOOTSTRAP_POINTS=624
AUTO_BOOTSTRAP_REGIONS=X,A,B,C,D,E,F,G,H,J,K,L,M,N,P
AUTO_UPDATE_ENABLED=true
AUTO_UPDATE_INTERVAL_SECONDS=1800
AUTO_UPDATE_RUN_IMMEDIATELY=true
ALLOW_STARTUP_BOOTSTRAP_FALLBACK=true
STARTUP_UPDATE_TIMEOUT_SECONDS=180

# ML rollout mode: deterministic (auto-promotes when ready), shadow, or ml
ML_WRITE_MODE=deterministic
